;intakes
;left
{part0_intake_left} = if({intake_left} != 1, animate2({intake_left}, 1.0, 0.0, 0.15, 0.0), 1)
{part1_intake_left} = if({intake_left} != 1, animate2({intake_left}, 1.0, 0.2, 0.2, 0.0), 1)
{part2_intake_left} = if({intake_left} != 1, animate2({intake_left}, 1.0, 0.6, 0.3, 0.0), 1)
{part3_intake_left} = if({intake_left} != 1, animate2({intake_left}, 1.0, 0.9, 0.1, 0.0), 1)
{head_left_front_intake_cover_rotX} -= 90'{part2_intake_left}
{head_left_back_intake_cover_rotX} += 90'{part2_intake_left}
{head_left_front_intake_cover_posY} -= 0.03{part0_intake_left}
{head_left_back_intake_cover_posY} -= 0.03{part0_intake_left}
{head_left_front_intake_cover_posZ} -= 0.99{part1_intake_left} + 0.01{part0_intake_left} + 0.01{part2_intake_left}
{head_left_back_intake_cover_posZ} += 0.99{part1_intake_left} + 0.01{part0_intake_left} + 0.01{part2_intake_left}
{head_left_intake_posY} -= 0.03{part0_intake_left} - 0.04{part2_intake_left}
{head_left_intake_fan_posY} += 0.13{part2_intake_left}
{head_left_intake_fan_rotY} += 360'{spin_left}
{head_left_intake_fan_disk_1_blade_1_rotZ} += 0' + 23'{part3_intake_left}
{head_left_intake_fan_disk_1_blade_2_rotX} += 0' + 23'{part3_intake_left}
{head_left_intake_fan_disk_1_blade_3_rotZ} -= 0' + 23'{part3_intake_left}
{head_left_intake_fan_disk_1_blade_4_rotX} -= 0' + 23'{part3_intake_left}
{head_left_intake_fan_disk_2_blade_1_rotZ} += 0' + 23'{part3_intake_left}
{head_left_intake_fan_disk_2_blade_2_rotX} += 0' + 23'{part3_intake_left}
{head_left_intake_fan_disk_2_blade_3_rotZ} -= 0' + 23'{part3_intake_left}
{head_left_intake_fan_disk_2_blade_4_rotX} -= 0' + 23'{part3_intake_left}
{head_left_intake_fan_disk_1_posY} += 0.1{part3_intake_left} + 0.13{part2_intake_left}
{head_left_intake_fan_disk_2_posY} += 0.1{part3_intake_left} + 0.13{part2_intake_left}

;right
{part0_intake_right} = if({intake_right} != 1, animate2({intake_right}, 1.0, 0.0, 0.15, 0.0), 1)
{part1_intake_right} = if({intake_right} != 1, animate2({intake_right}, 1.0, 0.2, 0.2, 0.0), 1)
{part2_intake_right} = if({intake_right} != 1, animate2({intake_right}, 1.0, 0.6, 0.3, 0.0), 1)
