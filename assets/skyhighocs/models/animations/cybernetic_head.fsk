{head_right_intake_posY} -= 0.03{part0_intake_right} - 0.03{part2_intake_right}
{head_right_intake_fan_posY} += 0.13{part2_intake_right}
{head_right_intake_fan_rotY} -= 360'{spin_right}
{head_right_intake_fan_disk_1_blade_1_rotZ} -= 0' + 23'{part3_intake_right}
